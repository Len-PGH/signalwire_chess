# SignalWire credentials — from your SignalWire Space dashboard
# (Space name is the full host, e.g. example.signalwire.com)
SIGNALWIRE_SPACE_NAME=your-space.signalwire.com
SIGNALWIRE_PROJECT_ID=your-project-id
SIGNALWIRE_TOKEN=your-api-token

# Basic auth that protects the /chess SWML webhook (pick any values).
# The app self-registers its SWML handler with these credentials.
SWML_BASIC_AUTH_USER=chess
SWML_BASIC_AUTH_PASSWORD=change-me
